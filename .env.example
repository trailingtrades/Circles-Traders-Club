# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway/Render/Neon/Supabase/DigitalOcean all
# provide one). Include ?sslmode=require for most managed providers.
DATABASE_URL="postgresql://user:password@localhost:5432/circles_lms"

# ─── Application ─────────────────────────────────────────────────────────────
# Public URL of the deployed app (used in email links).
APP_URL="http://localhost:3000"
APP_NAME="Circles Traders Club"
NEXT_PUBLIC_APP_NAME="Circles Traders Club"
# Shown on the "subscription expired" page.
NEXT_PUBLIC_CONTACT_EMAIL="support@example.com"

# ─── First admin account (used by `npm run db:seed`) ─────────────────────────
ADMIN_NAME="Institute Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-strong-password"

# ─── Sessions ────────────────────────────────────────────────────────────────
# Server-side idle timeout for student/admin sessions (minutes).
SESSION_IDLE_TIMEOUT_MINUTES="45"
# "true" (default) = logging in on a new device logs out other devices.
ENFORCE_SINGLE_STUDENT_SESSION="true"

# ─── Email ───────────────────────────────────────────────────────────────────
# Option A (recommended on Railway/PaaS): Brevo HTTPS API — set BREVO_API_KEY
# (Brevo → SMTP & API → API keys). Uses port 443, works where SMTP is blocked.
# SMTP_FROM is still used as the sender identity.
BREVO_API_KEY=""
# Option B: any SMTP provider (Resend, Brevo, Amazon SES, Mailgun, …).
# Leave SMTP_HOST empty in development: emails are printed to the console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Circles Traders Club <no-reply@example.com>"

# ─── Cron ────────────────────────────────────────────────────────────────────
# Shared secret for the daily reminder job:
#   curl -H "Authorization: Bearer $CRON_SECRET" $APP_URL/api/cron/reminders
CRON_SECRET="generate-a-long-random-string"
