// Prisma schema — Circles Traders Club LMS
// PostgreSQL. Run `npx prisma migrate deploy` in production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Admins — separate identity from students, separate login.
// ---------------------------------------------------------------------------
model Admin {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions            Session[]
  activityLogs        ActivityLog[]
  passwordResetTokens PasswordResetToken[]

  @@map("admins")
}

// ---------------------------------------------------------------------------
// Students — each has their own credentials and a subscription window.
// ---------------------------------------------------------------------------
enum StudentStatus {
  ACTIVE // normal account; access still gated by subscription dates
  DISABLED // temporarily disabled by admin; can be re-enabled
  REVOKED // permanently revoked by admin
}

enum MaterialAccessMode {
  ALL // sees every active material of their course (default)
  CUSTOM // sees only the materials explicitly granted to them
}

model Student {
  id                String        @id @default(cuid())
  fullName          String
  email             String        @unique
  passwordHash      String
  mobile            String?
  status            StudentStatus @default(ACTIVE)
  subscriptionStart DateTime
  subscriptionEnd   DateTime
  // Fee tracking (whole rupees). Due = feeTotal - feePaid.
  feeTotal          Int           @default(0)
  feePaid           Int           @default(0)
  materialAccess    MaterialAccessMode @default(ALL)
  notes             String?
  courseId          String?
  course            Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  lastLoginAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  sessions            Session[]
  activityLogs        ActivityLog[]
  passwordResetTokens PasswordResetToken[]
  remindersSent       ReminderSent[]
  materialGrants      StudentMaterialAccess[]
  indicatorGrants     StudentIndicatorAccess[]

  @@index([status])
  @@index([subscriptionEnd])
  @@map("students")
}

// ---------------------------------------------------------------------------
// Indicators — display-only entitlements. The dashboard shows students which
// indicators are included in their plan; there is nothing to open or download,
// the institute delivers the actual indicators separately.
// ---------------------------------------------------------------------------
model Indicator {
  id          String   @id @default(cuid())
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studentGrants StudentIndicatorAccess[]

  @@map("indicators")
}

model StudentIndicatorAccess {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  indicatorId String
  indicator   Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([studentId, indicatorId])
  @@map("student_indicator_access")
}

// Explicit per-student material grants (used when materialAccess = CUSTOM).
model StudentMaterialAccess {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([studentId, materialId])
  @@map("student_material_access")
}

// ---------------------------------------------------------------------------
// Courses — one today (the Options Selling Playbook); schema supports many.
// contentPath is relative to the protected /content directory on the server.
// ---------------------------------------------------------------------------
model Course {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  // Legacy single-file pointer; new courses carry their content as Materials.
  contentPath String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students  Student[]
  materials Material[]

  @@map("courses")
}

// ---------------------------------------------------------------------------
// Materials — the individual learning items inside a course.
//   HTML  : a file in the protected /content dir, served via authenticated route
//   VIDEO : an embedded recorded lecture (YouTube/Vimeo URL)
//   SHEET : a Google Sheet embedded read-only
//   LINK  : any external resource, opened in a new tab
// ---------------------------------------------------------------------------
enum MaterialType {
  HTML
  VIDEO
  SHEET
  LINK
}

model Material {
  id          String       @id @default(cuid())
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        MaterialType
  contentPath String? // HTML: path relative to /content
  url         String? // VIDEO / SHEET / LINK: external URL
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  studentGrants StudentMaterialAccess[]

  @@index([courseId, sortOrder])
  @@map("materials")
}

// ---------------------------------------------------------------------------
// Sessions — database-backed auth sessions. Cookie stores the raw token;
// only the SHA-256 hash is persisted. Belongs to a student OR an admin.
// ---------------------------------------------------------------------------
model Session {
  id           String   @id @default(cuid())
  tokenHash    String   @unique
  studentId    String?
  student      Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  adminId      String?
  admin        Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  remember     Boolean  @default(false)
  ip           String?
  userAgent    String?
  device       String?
  browser      String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime

  @@index([studentId])
  @@index([adminId])
  @@index([expiresAt])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Activity logs — full audit trail.
// ---------------------------------------------------------------------------
enum ActivityType {
  STUDENT_LOGIN
  STUDENT_LOGOUT
  STUDENT_LOGIN_FAILED
  ADMIN_LOGIN
  ADMIN_LOGOUT
  ADMIN_LOGIN_FAILED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  CONTENT_ACCESSED
  ACCESS_DENIED_EXPIRED
  STUDENT_CREATED
  STUDENT_UPDATED
  STUDENT_DELETED
  STUDENT_DISABLED
  STUDENT_ENABLED
  STUDENT_REVOKED
  SUBSCRIPTION_EXTENDED
  PASSWORD_CHANGED_BY_ADMIN
  FORCED_LOGOUT
  BULK_OPERATION
  REMINDER_EMAIL_SENT
  MATERIAL_CREATED
  MATERIAL_UPDATED
  MATERIAL_DELETED
  COURSE_CREATED
  COURSE_UPDATED
  COURSE_DELETED
  INDICATOR_CREATED
  INDICATOR_UPDATED
  INDICATOR_DELETED
}

model ActivityLog {
  id        String       @id @default(cuid())
  type      ActivityType
  studentId String?
  student   Student?     @relation(fields: [studentId], references: [id], onDelete: SetNull)
  adminId   String?
  admin     Admin?       @relation(fields: [adminId], references: [id], onDelete: SetNull)
  ip        String?
  userAgent String?
  device    String?
  browser   String?
  detail    String?
  createdAt DateTime     @default(now())

  @@index([type])
  @@index([studentId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ---------------------------------------------------------------------------
// Password reset tokens — single-use, short-lived, hash stored only.
// ---------------------------------------------------------------------------
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  adminId   String?
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([studentId])
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Reminder tracking — prevents duplicate expiry-reminder emails.
// ---------------------------------------------------------------------------
enum ReminderKind {
  DAYS_7
  DAYS_3
  DAYS_1
  EXPIRED
}

model ReminderSent {
  id              String       @id @default(cuid())
  studentId       String
  student         Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  kind            ReminderKind
  subscriptionEnd DateTime
  sentAt          DateTime     @default(now())

  @@unique([studentId, kind, subscriptionEnd])
  @@map("reminders_sent")
}
